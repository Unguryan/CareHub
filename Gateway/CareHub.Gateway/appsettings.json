{
  "Urls": "http://localhost:53615",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "Identity": {
    "Authority": "http://localhost:5001"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-connect-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/connect/{**catch-all}" }
      },
      "identity-users-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "patient-route": {
        "ClusterId": "patient-cluster",
        "Match": { "Path": "/api/patients/{**catch-all}" }
      },
      "appointment-route": {
        "ClusterId": "appointment-cluster",
        "Match": { "Path": "/api/appointments/{**catch-all}" }
      },
      "schedule-doctors-route": {
        "ClusterId": "schedule-cluster",
        "Match": { "Path": "/api/doctors/{**catch-all}" }
      },
      "schedule-slots-route": {
        "ClusterId": "schedule-cluster",
        "Match": { "Path": "/api/slots/{**catch-all}" }
      },
      "schedule-shifts-route": {
        "ClusterId": "schedule-cluster",
        "Match": { "Path": "/api/shifts/{**catch-all}" }
      },
      "billing-route": {
        "ClusterId": "billing-cluster",
        "Match": { "Path": "/api/invoices/{**catch-all}" }
      },
      "laboratory-route": {
        "ClusterId": "laboratory-cluster",
        "Match": { "Path": "/api/lab-orders/{**catch-all}" }
      },
      "audit-route": {
        "ClusterId": "audit-cluster",
        "Match": { "Path": "/api/audit-logs/{**catch-all}" }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "Match": { "Path": "/api/documents/{**catch-all}" }
      },
      "reporting-route": {
        "ClusterId": "reporting-cluster",
        "Match": { "Path": "/api/reports/{**catch-all}" }
      },
      "notifications-hub-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity/d1": { "Address": "http://localhost:5001" }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient/d1": { "Address": "http://localhost:5002" }
        }
      },
      "appointment-cluster": {
        "Destinations": {
          "appointment/d1": { "Address": "http://localhost:5003" }
        }
      },
      "schedule-cluster": {
        "Destinations": {
          "schedule/d1": { "Address": "http://localhost:5004" }
        }
      },
      "billing-cluster": {
        "Destinations": {
          "billing/d1": { "Address": "http://localhost:5005" }
        }
      },
      "laboratory-cluster": {
        "Destinations": {
          "laboratory/d1": { "Address": "http://localhost:5006" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification/d1": { "Address": "http://localhost:5007" }
        }
      },
      "audit-cluster": {
        "Destinations": {
          "audit/d1": { "Address": "http://localhost:5008" }
        }
      },
      "document-cluster": {
        "Destinations": {
          "document/d1": { "Address": "http://localhost:5009" }
        }
      },
      "reporting-cluster": {
        "Destinations": {
          "reporting/d1": { "Address": "http://localhost:5010" }
        }
      }
    }
  }
}
