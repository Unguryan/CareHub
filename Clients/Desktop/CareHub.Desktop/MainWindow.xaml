<Window x:Class="CareHub.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:CareHub.Desktop.Converters"
        mc:Ignorable="d"
        Title="CareHub Desktop" Height="720" Width="1120"
        Background="{DynamicResource WindowBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                           Text="CareHub Desktop" />
                <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Border Visibility="{Binding IsSignedIn, Converter={StaticResource InverseBoolToVis}}"
                Style="{StaticResource Card}">
            <StackPanel MaxWidth="360" HorizontalAlignment="Left">
                <TextBlock FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12" Text="Sign in" />
                <Label Content="Phone" Target="{Binding ElementName=PhoneBox}" />
                <TextBox x:Name="PhoneBox" Text="{Binding LoginPhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                <Label Content="Password" Target="{Binding ElementName=PassBox}" />
                <PasswordBox x:Name="PassBox" Margin="0,0,0,12" PasswordChanged="PassBox_OnPasswordChanged" />
                <Button Content="Sign in" Style="{StaticResource PrimaryButton}" Command="{Binding LoginCommand}" />
            </StackPanel>
        </Border>

        <TabControl Visibility="{Binding IsSignedIn, Converter={StaticResource BoolToVis}}">
            <TabItem Header="Patients">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox Width="220" Text="{Binding PatientSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search query" />
                        <Button Content="Search" Margin="8,0,0,0" Padding="12,6" Command="{Binding SearchPatientsCommand}" />
                        <Button Content="Sign out" Margin="16,0,0,0" Padding="12,6" Command="{Binding LogoutCommand}" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Patients}" IsReadOnly="True" AutoGenerateColumns="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FirstName}" Width="*" />
                            <DataGridTextColumn Header="Last" Binding="{Binding LastName}" Width="*" />
                            <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120" />
                            <DataGridTemplateColumn Header="Check-in">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Check-in"
                                                Command="{Binding DataContext.CheckInCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" Padding="6,2" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Registration">
                <StackPanel Margin="12" MaxWidth="400" HorizontalAlignment="Left">
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="New patient" />
                    <Label Content="First name" Target="{Binding ElementName=N1}" />
                    <TextBox x:Name="N1" Text="{Binding NewFirst, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Last name" Target="{Binding ElementName=N2}" />
                    <TextBox x:Name="N2" Text="{Binding NewLast, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Phone" Target="{Binding ElementName=N3}" />
                    <TextBox x:Name="N3" Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Email" Target="{Binding ElementName=N4}" />
                    <TextBox x:Name="N4" Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}" />
                    <Label Content="Date of birth" />
                    <DatePicker SelectedDate="{Binding NewDob}" Margin="0,0,0,8" />
                    <Button Content="Register" HorizontalAlignment="Left" Padding="12,6"
                            Command="{Binding RegisterPatientCommand}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Appointments">
                <StackPanel Margin="12" MaxWidth="480" HorizontalAlignment="Left">
                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Book appointment" />
                    <TextBlock Text="No GUID typing. Use category and searchable selectors."
                               Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,0,8" />

                    <Label Content="Patient search" />
                    <TextBox Text="{Binding BookPatientSearch, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Margin="0,4,0,8"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              ItemsSource="{Binding BookPatientsView}"
                              SelectedItem="{Binding SelectedBookPatient}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding LastName}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding FirstName}" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding PhoneNumber}" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Label Content="Category (specialty)" />
                    <ComboBox ItemsSource="{Binding SpecialtyOptions}"
                              SelectedItem="{Binding SelectedSpecialty}"
                              Margin="0,0,0,8" />

                    <Label Content="Doctor search" />
                    <TextBox Text="{Binding BookDoctorSearch, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Margin="0,4,0,8"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              ItemsSource="{Binding BookDoctorsView}"
                              SelectedItem="{Binding SelectedBookDoctor}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding LastName}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding FirstName}" />
                                    <Run Text=" - " />
                                    <Run Text="{Binding Specialty}" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding BranchCaption}" />
                            <TextBlock Text="{Binding BranchHint}" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Label Content="Date" />
                    <DatePicker SelectedDate="{Binding BookDate}" Margin="0,0,0,8" />

                    <DockPanel Margin="0,0,0,4">
                        <Label Content="Available times" DockPanel.Dock="Left" />
                        <Button Content="Refresh slots" Padding="8,4" DockPanel.Dock="Right"
                                Command="{Binding LoadSlotsCommand}" />
                    </DockPanel>
                    <ListBox ItemsSource="{Binding AvailableSlots}"
                             SelectedItem="{Binding SelectedSlotTime}"
                             Height="100" Margin="0,0,0,8" />

                    <Label Content="Start (manual override)" />
                    <TextBox Text="{Binding BookScheduledAtText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Example: 2026-04-06T14:30" Margin="0,0,0,8" />
                    <Label Content="Duration (min)" />
                    <TextBox Text="{Binding BookDuration, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <Button Content="Book" HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"
                            Command="{Binding BookAppointmentCommand}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="Lab queue" Visibility="{Binding ShowLabTab, Converter={StaticResource BoolToVis}}">
                <DockPanel Margin="8">
                    <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Margin="0,0,0,8" Padding="12,6"
                            Content="Refresh queue" Command="{Binding LoadLabQueueCommand}" />
                    <DataGrid ItemsSource="{Binding LabOrders}" IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order ID" Binding="{Binding Id}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" />
                            <DataGridTextColumn Header="Patient" Binding="{Binding PatientId}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Print / PDF">
                <StackPanel Margin="12" MaxWidth="420" HorizontalAlignment="Left">
                    <TextBlock TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,8"
                               Text="Download a document by GUID, then print from your PDF viewer." />
                    <Label Content="Document ID" />
                    <TextBox Text="{Binding DocumentId, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Content="Save PDF…" Margin="0,8,0,0" HorizontalAlignment="Left" Padding="12,6"
                            Command="{Binding DownloadDocumentCommand}" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
